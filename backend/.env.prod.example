# Copy to backend/.env on the droplet and fill in real values.
# The POSTGRES_* / MINIO_ROOT_* values below must match those in the root .env.

# PostgreSQL (host "postgres" is the docker service name)
DATABASE_URL=asyncpg://postgres:CHANGE_ME_STRONG_PG_PASSWORD@postgres:5432/platform_db

# MongoDB
MONGODB_URL=mongodb://mongo:27017
MONGODB_DB_NAME=nexushub

# Redis
REDIS_URL=redis://redis:6379/0

# JWT — generate with: openssl rand -base64 48
SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_BASE64_48

# MinIO (must match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD in root .env)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_USER
MINIO_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD

# Email
# DigitalOcean blocks outbound SMTP on new droplets, so either:
#   (a) set EMAIL_VERIFICATION_REQUIRED=false and accounts are active on signup, or
#   (b) use an ESP (SendGrid / Mailgun / Resend) — set SMTP_HOST/PORT/USER/PASSWORD accordingly.
EMAIL_VERIFICATION_REQUIRED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
