# Copy this file to .env on the droplet (same directory as docker-compose.prod.yml)
# and fill in real values. Generate strong secrets with:
#   openssl rand -base64 32

# ── Postgres (used by the postgres service) ───────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PG_PASSWORD
POSTGRES_DB=platform_db

# ── MinIO root credentials (used by the minio service) ─
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
